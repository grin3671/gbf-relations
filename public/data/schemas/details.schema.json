{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "name",
      "desc",
      "images",
      "links",
      "cv",
      "cv-links"
    ],
    "properties": {
      "id": {
        "type": "integer",
        "description": "Unique character identifier"
      },
      "name": {
        "type": "string",
        "description": "Character name"
      },
      "desc": {
        "type": "string",
        "description": "Character description"
      },
      "images": {
        "type": "array",
        "description": "List of character images",
        "items": {
          "type": "object",
          "properties": {
            "image": {
              "type": "string",
              "description": "Path to image",
              "pattern": "^https://.*\\.png$"
            },
            "label": {
              "type": "string",
              "description": "Image label or caption"
            }
          },
          "required": ["image", "label"]
        }
      },
      "links": {
        "type": "array",
        "description": "List of wiki page links",
        "items": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://gbf\\.wiki/.*$"
        }
      },
      "cv": {
        "type": "string",
        "description": "Seiyuu (voice actor) name"
      },
      "cv-links": {
        "type": "array",
        "description": "List of seiyuu profile links",
        "items": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://myanimelist\\.net/people/.*$"
        }
      }
    }
  }
}
